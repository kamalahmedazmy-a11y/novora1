# Server port (optional, default 5000)
PORT=5000

# MongoDB connection string (required for auth, progress, chapters)
# Local: mongodb://localhost:27017/novora
# Cloud: mongodb+srv://user:pass@cluster.mongodb.net/novora
MONGO_URI=mongodb://localhost:27017/novora

# Secret used to sign JWTs (required). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# ---- Security (Phase 0) ----
# NODE_ENV=production           # hides internal 500 details from clients
# CLIENT_ORIGINS=https://app.novora.com,http://localhost:5173   # CORS allowlist (unset = allow all, dev only)
# ACCESS_TOKEN_TTL=15m          # short-lived access token
# REFRESH_TOKEN_DAYS=7          # refresh token lifetime

# ---- Email delivery (optional) ----
# If SMTP_HOST is set, notifications are emailed via nodemailer; otherwise they
# only log to the console. For Gmail: enable 2FA, create an App Password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-sender@gmail.com
# SMTP_PASS=your-16-char-app-password
# MAIL_FROM=your-sender@gmail.com

# ---- SMS delivery (optional, Twilio) ----
# All three required to send real SMS; otherwise SMS logs to the console.
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=
